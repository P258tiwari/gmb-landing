# ── Google Places API ──────────────────────────────────────────
# Enable the "Places API (New)" in Google Cloud Console
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_MAPS_API_KEY=your_google_places_api_key_here

# ── AI Summary (optional) ──────────────────────────────────────
# Anthropic Claude API key for enhanced AI-generated summaries
# If not set, a rule-based summary is generated automatically
# https://console.anthropic.com
AI_PROVIDER_API_KEY=your_anthropic_api_key_here

# ── Site URL ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── WhatsApp number (with country code, no +) ─────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=918452013047

# Contact form -> Google Sheet Apps Script Web App endpoint
# Deploy Apps Script as a Web App and paste the /exec URL here.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Production database (Supabase) ────────────────────────────
# Uncomment and configure for production deployment
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
